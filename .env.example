# Required: PostgreSQL connection string used by cmd/server and local tools.
DATABASE_URL=postgres://user:password@localhost:5432/learning_video?sslmode=disable

# Required: absolute http(s) URL used to prefix relative media paths in Feed API.
PUBLIC_ASSET_BASE_URL=https://storage.googleapis.com/your-bucket

# Optional, default ":8080".
API_ADDR=:8080

# Optional, default "false".
# false: require GCP API Gateway userinfo header.
# true: allow fallback to Authorization: Bearer <JWT> when gateway header is absent.
DEV_MODE=false

# Optional, default "X-Apigateway-Api-Userinfo".
API_GATEWAY_USERINFO_HEADER=X-Apigateway-Api-Userinfo
